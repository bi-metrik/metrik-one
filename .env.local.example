# Supabase
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# App
NEXT_PUBLIC_BASE_DOMAIN=metrikone.co
NEXT_PUBLIC_APP_NAME=MéTRIK ONE

# ── Valida API (compliance dual / standalone) ─────────────────────────────
# Base de la API de Valida (mismo deploy, distinto dominio)
VALIDA_API_BASE=https://api.valida.metrikone.co

# API Key — una por workspace consumidor:
#   - alma-afi tiene su propia API key (UI 1: consulta de listas restrictivas)
#   - metrik tiene su propia API key (UI 2: comparativa Informa, requiere admin)
# La Edge Function `compliance-dual` resuelve workspace_origen por la key.
VALIDA_API_KEY=val_...

# Secret para acceso admin de auditoria. Solo workspace metrik debe tenerlo
# en su entorno. Habilita /v1/compliance/dual/list, /{id}, /{id}/audit, /metrics.
METRIK_AUDIT_SECRET=
